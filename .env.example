APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

SESSION_DRIVER=array

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

BROADCAST_CONNECTION=reverb
METRICS_BROADCAST_CHANNEL=metrics
METRICS_BROADCAST_EVENT=metrics.updated
METRICS_BROADCAST_INTERVAL=5
METRICS_CACHE_KEY=metrics.snapshot
METRICS_CACHE_TTL=15

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=https
REVERB_TLS_CERT=/tmp/reverb/certs/reverb.crt
REVERB_TLS_KEY=/tmp/reverb/certs/reverb.key
REVERB_TLS_PASSPHRASE=
REVERB_TLS_VERIFY_PEER=false
REVERB_TLS_ALLOW_SELF_SIGNED=true
REVERB_APP_MAX_MESSAGE_SIZE=500000
REVERB_MAX_REQUEST_SIZE=500000
REVERB_APP_PING_INTERVAL=120
REVERB_APP_ACTIVITY_TIMEOUT=180

PROMETHEUS_BASE_URL=http://prometheus:9090
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=
PROMETHEUS_TIMEOUT=5
PROMETHEUS_CONNECT_TIMEOUT=2
PROMETHEUS_QUERY_CPU_USAGE_PERCENT="100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)"
PROMETHEUS_QUERY_CPU_CORES_USAGE_PERCENT="100 - (irate(node_cpu_seconds_total{mode=\"idle\"}[1m]) * 100)"
PROMETHEUS_QUERY_CPU_IOWAIT_PERCENT="avg(irate(node_cpu_seconds_total{mode=\"iowait\"}[1m])) * 100"
PROMETHEUS_QUERY_MEMORY_USAGE_PERCENT="100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))"
PROMETHEUS_QUERY_SWAP_USAGE_PERCENT="100 * (1 - (node_memory_SwapFree_bytes / clamp_min(node_memory_SwapTotal_bytes, 1)))"
PROMETHEUS_QUERY_MEMORY_CACHED_MB="node_memory_Cached_bytes / 1024 / 1024"
PROMETHEUS_QUERY_DISK_ROOT_USED_PERCENT="100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"rootfs\",fstype!=\"tmpfs\"} * 100) / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"rootfs\",fstype!=\"tmpfs\"})"
PROMETHEUS_QUERY_DISK_WRITE_MB="sum(irate(node_disk_written_bytes_total[1m])) / 1024 / 1024"
PROMETHEUS_QUERY_DISK_READ_MB="sum(irate(node_disk_read_bytes_total[1m])) / 1024 / 1024"
PROMETHEUS_QUERY_NETWORK_DOWNLOAD_MB="sum(irate(node_network_receive_bytes_total{device!=\"lo\"}[1m])) / 1024 / 1024"
PROMETHEUS_QUERY_NETWORK_UPLOAD_MB="sum(irate(node_network_transmit_bytes_total{device!=\"lo\"}[1m])) / 1024 / 1024"
PROMETHEUS_QUERY_NETWORK_ERRORS_TOTAL="sum(node_network_receive_errs_total{device!=\"lo\"}) + sum(node_network_transmit_errs_total{device!=\"lo\"})"
PROMETHEUS_QUERY_UPTIME_SECONDS="time() - node_boot_time_seconds"
PROMETHEUS_QUERY_LOAD_AVERAGE_1M="node_load1"
PROMETHEUS_QUERY_LOAD_AVERAGE_5M="node_load5"
PROMETHEUS_QUERY_LOAD_AVERAGE_15M="node_load15"
PROMETHEUS_QUERY_PROCESSES_RUNNING="node_procs_running"
PROMETHEUS_QUERY_FILE_DESCRIPTORS_ALLOCATED="node_filefd_allocated"
PROMETHEUS_QUERY_CONTEXT_SWITCHES_PER_SECOND="sum(irate(node_context_switches_total[1m]))"
PROMETHEUS_QUERY_PROCESS_LIST_ALL="namedprocess_namegroup_cpu_seconds_total"
PROMETHEUS_QUERY_PROCESS_CPU_PERCENT="sum by (groupname) (irate(namedprocess_namegroup_cpu_seconds_total[1m])) * 100"
PROMETHEUS_QUERY_PROCESS_MEMORY_RESIDENT_BYTES="namedprocess_namegroup_memory_bytes{memtype=\"resident\"}"
PROMETHEUS_QUERY_PROCESS_MEMORY_VIRTUAL_BYTES="namedprocess_namegroup_memory_bytes{memtype=\"virtual\"}"
PROMETHEUS_QUERY_PROCESS_THREADS="namedprocess_namegroup_num_threads"
PROMETHEUS_QUERY_PROCESS_DISK_READ_BYTES_PER_SECOND="irate(namedprocess_namegroup_read_bytes_total[1m])"
PROMETHEUS_QUERY_PROCESS_DISK_WRITE_BYTES_PER_SECOND="irate(namedprocess_namegroup_write_bytes_total[1m])"
PROMETHEUS_QUERY_PROCESS_CONTEXT_SWITCHES_PER_SECOND="irate(namedprocess_namegroup_context_switches_total[1m])"
PROMETHEUS_QUERY_PROCESS_OPEN_FILEDESC="namedprocess_namegroup_open_filedesc"
PROMETHEUS_QUERY_PROCESS_UPTIME_SECONDS="time() - namedprocess_namegroup_oldest_start_time_seconds"
